APP_NAME=ai-mems
DATABASE_URL=sqlite:///./memes.db
STORAGE_DIR=./storage

# Если поставить в true — endpoint /memes/random сможет генерировать новый мем,
# когда в базе нет картинок (или когда client просит force_generate=true)
ALLOW_GENERATION=true

# Простейший “AI”-режим по умолчанию — локальная генерация картинки с текстом.
# Чтобы подключить реальный генератор, можно реализовать свой провайдер в app/ai.py
# и/или установить OPENAI_API_KEY и python-пакет openai.
AI_PROVIDER=local_text
OPENAI_API_KEY=
